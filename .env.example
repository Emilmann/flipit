# Flipit – Beispiel-Konfiguration.
# Kopiere diese Datei nach `.env` und passe die Werte an. `.env` wird NICHT eingecheckt.

# Anzeigename der App (Streamlit-Titel)
APP_TITLE=Flipit

# Verzeichnis für persistierte Daten (relativ zur Projekt-Wurzel oder absoluter Pfad)
DATA_DIR=data

# Verzeichnis für heruntergeladene Inserats-Bilder (Default: <DATA_DIR>/images)
IMAGE_DIR=data/images

# SQLite-Datei für persistierte Inserate (Default: <DATA_DIR>/flipit.db)
DB_PATH=data/flipit.db

# --- Scraper (MVP-2) ---
# Vordefinierte Fahrzeugmodelle als Such-Keywords, kommasepariert
SEARCH_MODELS=Audi A3, VW Golf, BMW 3er
# Budget-Range in Euro
PRICE_MIN=6000
PRICE_MAX=8000
# Basis-URL der willhaben-Gebrauchtwagensuche (i.d.R. unverändert lassen)
WILLHABEN_BASE_URL=https://www.willhaben.at/iad/gebrauchtwagen/auto/gebrauchtwagenboerse
# Freundliches Rate-Limiting: Pause (Sekunden) zwischen Modell-Abfragen
REQUEST_DELAY=2.0
# HTTP-Timeout pro Request (Sekunden)
REQUEST_TIMEOUT=20
# User-Agent-Header für Requests
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64; rv:128.0) Gecko/20100101 Firefox/128.0

# --- Scoring (MVP-4) ---
# Gewichte der Score-Faktoren (werden intern auf Summe 1 normalisiert)
SCORE_WEIGHT_PRICE=0.35
SCORE_WEIGHT_MILEAGE=0.30
SCORE_WEIGHT_AGE=0.20
SCORE_WEIGHT_DESCRIPTION=0.15
# Kilometerstand-Schwellen: best = Score 1.0, worst = Score 0.0
SCORE_MILEAGE_BEST=50000
SCORE_MILEAGE_WORST=250000
# Alters-Schwellen in Jahren: best = Score 1.0, worst = Score 0.0
SCORE_AGE_BEST=0
SCORE_AGE_WORST=20
# Score-Änderung pro Beschreibungs-Schlagwort-Treffer (ausgehend von 0.5)
SCORE_KEYWORD_STEP=0.2
# Optionale eigene Schlagwort-Listen (kommasepariert) – sonst sinnvolle Defaults
# SCORE_NEGATIVE_KEYWORDS=unfall,defekt,motorschaden,bastler
# SCORE_POSITIVE_KEYWORDS=scheckheft,garantie,unfallfrei,gepflegt
