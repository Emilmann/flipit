# Flipit – Beispiel-Konfiguration.
# Kopiere diese Datei nach `.env` und passe die Werte an. `.env` wird NICHT eingecheckt.

# Anzeigename der App (Streamlit-Titel)
APP_TITLE=Flipit

# Verzeichnis für persistierte Daten (relativ zur Projekt-Wurzel oder absoluter Pfad)
DATA_DIR=data

# Verzeichnis für heruntergeladene Inserats-Bilder (Default: <DATA_DIR>/images)
IMAGE_DIR=data/images
